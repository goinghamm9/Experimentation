# HFT Agent Environment Variables
# Copy to .env and fill in your credentials

# Robinhood
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_MFA_CODE=

# Alpaca
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Interactive Brokers
# (Uses TWS/Gateway connection - no API keys needed, just host/port)

# TimescaleDB
TIMESCALE_PASSWORD=your_secure_password

# Redis (if auth enabled)
REDIS_PASSWORD=

# Application
APP_MODE=paper
LOG_LEVEL=INFO
