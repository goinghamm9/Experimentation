# --- Anthropic (runtime parsing model: keep this cheap) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Jira Cloud ---
JIRA_BASE_URL=https://samprand.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
# Testing mode (default true): Approve runs the full flow but mints a DRY-*
# key instead of creating a real issue. Set false to create real issues.
JIRA_DRY_RUN=true

# --- Gmail (poller watches a label on the existing inbox) ---
GMAIL_LABEL=jira-intake
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# --- Dashboard (single-operator basic auth) ---
DASHBOARD_USER=operator
DASHBOARD_PASS=change-me

# --- App ---
DATABASE_PATH=email_to_jira.db
DEFAULT_PROJECT_KEY=MSA
